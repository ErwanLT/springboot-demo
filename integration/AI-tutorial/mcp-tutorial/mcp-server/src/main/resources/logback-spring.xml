<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>/Users/erwanletutour/IdeaProjects/springboot-demo/integration/AI-tutorial/mcp-tutorial/mcp-server/logs/mcp-server.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="FILE" />
    </root>

    <logger name="org.springframework.web.reactive.function.client.ExchangeFunctions" level="DEBUG"/>
    <logger name="fr.eletutour" level="DEBUG"/>
</configuration>